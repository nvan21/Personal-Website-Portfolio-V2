---
interface Props {
  title: string;
  authors: string;
  content: string;
  date: string;
  thumbnailUrl?: string;
  githubUrl?: string;
  publicationUrl?: string;
  lab: string;
  school: string;
}

const {
  title,
  authors,
  content,
  date,
  thumbnailUrl,
  githubUrl,
  publicationUrl,
  lab,
  school,
} = Astro.props;

import { Icon } from "astro-icon/components";
---

<div class="rounded-xl border border-body/25 bg-navbar p-6">
  <div class="flex space-x-8">
    {thumbnailUrl && <img src={thumbnailUrl} class="h-full w-2/5 rounded-lg" />}

    <div class={`flex flex-col justify-center space-y-3 ${thumbnailUrl ? 'w-3/5' : 'w-full'}`}>
      <div class="text-header font-source text-2xl font-semibold tracking-tight">{title}</div>
      <div class="text-body font-lexend text-sm italic">{authors}</div>
      <div class="flex items-center space-x-2">
        <Icon name="mdi:school-outline" class="h-4 w-4 text-body/60 shrink-0" />
        <span class="font-lexend text-body/70 text-xs">{lab} &mdash; {school}</span>
      </div>
      <div class="text-body font-lexend text-base leading-relaxed">{content}</div>
      <div class="flex items-center justify-between pt-1">
        <div class="flex space-x-2">
          {githubUrl && (
            <a
              href={githubUrl}
              target="_blank"
              class="rounded-md border border-body/25 bg-navbar p-1.5 text-body transition-colors hover:border-body/50 hover:text-header"
            ><Icon name="mdi:github" class="h-5 w-5" /></a>
          )}
          {publicationUrl && (
            <a
              href={publicationUrl}
              target="_blank"
              class="rounded-md border border-body/25 bg-navbar p-1.5 text-body transition-colors hover:border-body/50 hover:text-header"
            ><Icon name="mdi:note-text" class="h-5 w-5" /></a>
          )}
        </div>
        <time class="font-lexend text-body/60 text-xs tracking-wide">
          {date}
        </time>
      </div>
    </div>
  </div>
</div>
