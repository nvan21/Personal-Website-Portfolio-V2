---
import { getCollection, type CollectionEntry } from "astro:content";

import BackdropText from "./BackdropText.astro";

// Fetch all entries from the 'industry' collection
const allIndustryEntries = await getCollection("industry");

// Pre-render the content for each entry to make it available in the template
const entriesWithContent = await Promise.all(
  allIndustryEntries.map(async (entry) => {
    const { Content } = await entry.render();
    return {
      ...entry, // Keep all original entry properties
      Content, // Add the rendered Content component
    };
  }),
);

// Create one flat array of all projects, sorted chronologically (newest first)
const allProjectsSorted = entriesWithContent.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

---

<div id="industry">
  <BackdropText backdropText="Industry" text="Industry" />

  {/* Single Flexbox Timeline Container */}
  <div class="flex flex-col">
    {
      allProjectsSorted.map((project, index) => {
        const prevProject = allProjectsSorted[index - 1];
        const showCompanyHeader =
          index === 0 || prevProject.data.company !== project.data.company;

        const { Content } = project;

        return (
          // Each timeline item is a flex row
          <div class="flex flex-row">
            {/* Gutter */}
            <div class="relative mr-6 w-12 flex-shrink-0">
              {/* Vertical Line */}
              <div class="bg-body/20 absolute top-0 left-1/2 h-full w-px -translate-x-1/2" />

              {/* Circle */}
              <div class="bg-white ring-background absolute top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-body/20 ring-4 shadow-sm">
                <img
                  class="rounded-full"
                  src={project.data.thumbnailUrl}
                  alt={`${project.data.project} thumbnail`}
                />
              </div>

              {/* Horizontal Connector Line */}
              <div class="bg-body/20 absolute top-1/2 left-full h-px w-6 -translate-y-1/2" />
            </div>

            {/* Content Column */}
            <div class="w-full pb-10">
              {showCompanyHeader && (
                <div class="font-lexend text-header my-4 flex justify-start text-3xl font-bold">
                  {project.data.company}
                </div>
              )}

              {/* Content Card */}
              <div class="rounded-xl border border-body/25 bg-navbar p-5">
                <div class="flex flex-col gap-3">
                  <div>
                    <p class="text-header font-source mb-0.5 text-xl font-semibold tracking-tight">
                      {project.data.project}
                    </p>
                    <p class="text-body font-lexend text-sm">
                      {project.data.role}
                    </p>
                  </div>
                  <div class="text-body prose prose-li:font-lexend text-base max-w-none min-w-0 flex-grow leading-relaxed">
                    <Content />
                  </div>
                  <div class="flex flex-row flex-wrap items-center justify-between gap-2 pt-1">
                    <div class="flex flex-row flex-wrap gap-1.5">
                      {project.data.skills.map((skill) => (
                        <span class="font-lexend text-body/80 rounded-md border border-body/20 px-2.5 py-0.5 text-xs tracking-wide">
                          {skill}
                        </span>
                      ))}
                    </div>

                    <time class="font-lexend text-body/60 text-xs tracking-wide">
                      {new Intl.DateTimeFormat("en-US", {
                        month: "long",
                        year: "numeric",
                      }).format(project.data.date)}
                    </time>
                  </div>
                </div>
              </div>
            </div>
          </div>
        );
      })
    }
  </div>
</div>
